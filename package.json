{
	"name": "anna-portfolio",
	"version": "0.9.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "npm run generate:sitemaps",
		"build": "tsgo --noEmit && vite build",
		"build:upwork": "VITE_UPWORK_MODE=true VITE_SITE_ORIGIN=https://upwork.harrisonsoftware.dev npm run build",
		"preview": "sirv dist --port 4173 --cors",
		"postinstall": "patch-package",
		"generate:sitemaps": "tsx node-scripts/generate-sitemaps.ts"
	},
	"dependencies": {
		"@solidjs/meta": "^0.29.4",
		"@solidjs/router": "^0.16.1",
		"@solidjs/start": "^2.0.0-alpha.2",
		"@solidjs/vite-plugin-nitro-2": "^0.1.0",
		"altcha": "^3.0.4",
		"solid-js": "^1.9.12"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.2",
		"@types/node": "^22.15.3",
		"@typescript/native-preview": "^7.0.0-dev.20260321.1",
		"autoprefixer": "^10.4.27",
		"patch-package": "^8.0.1",
		"postcss": "^8.5.8",
		"sirv-cli": "^3.0.1",
		"srvx": "0.9.8",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.0",
		"vite-tsconfig-paths": "^6.1.1"
	},
	"engines": {
		"node": ">=22.0.0"
	}
